PORT=3000
BASE_URL=https://your-ngrok-or-domain.com

# JWT 用户登录（必填：生产环境请设置复杂密钥）
JWT_SECRET=your-jwt-secret-change-in-production

# 阿里云验证码（二选一：号码认证服务 或 短信服务；不填则不会真发短信，验证码会打印在后端终端）
ALIYUN_SMS_PROVIDER=dypns
# 使用「号码认证服务」时填 dypns，签名与模板须从号码认证控制台「赠送签名/赠送模板」获取：
#   https://dypns.console.aliyun.com/smsCertParamsConfig/sign
#   https://dypns.console.aliyun.com/smsCertParamsConfig/template
# 使用「短信服务」时填 dysms 或不填，签名与模板在短信服务控制台申请
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=     # 签名名称（号码认证请用赠送签名）
ALIYUN_SMS_TEMPLATE_CODE= # 模板 CODE（号码认证请用赠送模板，模板变量需含 code、min）

# Twilio（仅用于通话、录音；验证码已改用阿里云）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# 阿里云智能语音（2.5 期 ASR/TTS，与短信可共用 AccessKey）
ALIYUN_REGION=cn-shanghai
# 兼容旧变量：不推荐
# ALI_APP_KEY=
# 推荐：按语言分别配置（用于快速切换日语/英语）
ALI_APP_KEY_JA=
ALI_APP_KEY_EN=
# 日语 TTS 发音人：
# - 推荐不填：将使用你在阿里云控制台「项目功能配置」里选择的默认发音人（如「智也」）
# - 若你需要强制指定，可填 voice code（控制台项目功能配置里可见）
# ALIYUN_TTS_VOICE=

# OpenAI（录音转写 + 摘要）
OPENAI_API_KEY=

# 可选：用 DeepSeek 从搜索结果中提取电话（推荐，见 https://platform.deepseek.com）
DEEPSEEK_API_KEY=
# 可选：AI 对话加速（见 docs/VOICE_SPEED_OPTIMIZATION.md）
# 当前仅使用 DeepSeek，未开通 OpenAI
# AI_MAX_TOKENS=80          # 降低可减少 LLM 生成时间（默认 80）
# AI_MAX_HISTORY_TURNS=3    # 仅保留最近 N 轮对话，减少输入 token
# AI_STREAM=0               # DeepSeek 流式默认开启，设 0 可关闭
# AI_REQUEST_TIMEOUT_MS=15000
# TTS_SPEECH_RATE=50        # TTS 语速（-500~500，默认 50，0=正常速度）
# DEBUG_VOICE=1             # 打印 ASR/LLM/TTS 耗时
# USE_TWILIO_GATHER=1       # 启用 Twilio Gather 模式（内置语音识别，跳过下载+ffmpeg+ASR，大幅提速）
# 可选：网页搜索来源（Serper 或留空则用 DuckDuckGo）
SERPER_API_KEY=

# 本地调试可禁用自动重试拨号调度器（避免刷 Twilio 错误）
# DISABLE_RETRY_SCHEDULER=1

# Wikidata Query Service（日本米其林 SPARQL；遇 403 Too Many Reqs 时会自动退避重试）
# WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
# 建议填可联系邮箱或项目主页，写入 User-Agent（降低被限流概率）
# WIKIDATA_USER_AGENT_CONTACT=https://你的域名或邮箱
# WIKIDATA_MAX_RETRIES=6
# WIKIDATA_RETRY_BASE_MS=12000
# WIKIDATA_REQUEST_TIMEOUT_MS=55000

# 店铺爬虫：OpenStreetMap Overpass
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# 生产建议自建 Overpass 或镜像，避免公共实例繁忙/限流
# OVERPASS_MAX_RETRIES=3
# OVERPASS_RETRY_BASE_MS=2000
# 每城写入 crawled 最大条数（米其林优先，默认 15，范围 5～50）
# CRAWLER_TARGET_PER_CITY=15
# 以下为「开关」，必须同时等于字符 1 才生效（不是 true/yes）
# Tabelog：默认关闭；开启后每城最多插入 5 条（且代码会为 Tabelog 预留槽位，避免被米其林占满）
# CRAWLER_INCLUDE_TABELOG=1
# DeepSeek 爬取文案兜底：须已有 DEEPSEEK_API_KEY，且下面为 1
# CRAWLER_DEEPSEEK_REFINE=1
