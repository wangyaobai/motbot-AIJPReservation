PORT=3000
BASE_URL=https://your-ngrok-or-domain.com

# Twilio（通话、录音、短信）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenAI（录音转写 + 摘要）
OPENAI_API_KEY=

# 可选：用 DeepSeek 从搜索结果中提取电话（推荐，见 https://platform.deepseek.com）
DEEPSEEK_API_KEY=
# 可选：网页搜索来源（Serper 或留空则用 DuckDuckGo）
SERPER_API_KEY=
